---
// Copyright (C) Retty, Inc.
// foodre Pattern C — コンテンツ更新型（カフェ・パン屋・居酒屋・バー系）（#78）
// 川野さん設計: ライブステータスバー・今日のおすすめ・店主日誌・食材入荷情報・LINE CTA
// 元デザイン HTML（03_pattern-C_content-update.html）ベースで完全差し替え（store.json 変数バインド済み）
//
// 自己完結型ページ: BaseLayout を使わず、直接 <!DOCTYPE html>...<html><head><body> を持つ。
// BaseLayout のヘッダー/フッター/グローバル CSS 競合を根本的に排除する。
import { UI } from '../lib/i18n';
import {
  formatHours, formatBudget, gmapsUrl,
  type Store, type WeeklyItem, type DiaryEntry,
} from '../lib/store';

export interface Props { store: Store; }
const { store } = Astro.props;
const ui = UI;
const hours = formatHours(store);
const budget = formatBudget(store);
const maps = gmapsUrl(store);
// catchphrase → description → special_info の優先順位でヒーロー説明文を選択（#277）
const heroDesc = store.catchphrase || store.description || store.special_info || '';
const reservationLink = store.reservation_url ?? maps;
// #46: reservation_url がない場合は電話 CTA のみ。tel もなければ非表示。
const reservationUrl = store.reservation_url ?? null;

// NOW OPEN ステータス判定（簡易: 現在日 vs 曜日別営業時間）
const today = new Date();
const dayNames = ['sun', 'mon', 'tue', 'wed', 'thu', 'fri', 'sat'];
const todayKey = dayNames[today.getDay()];
const todayHours = store.hours?.[todayKey];
const isOpenToday = !!todayHours?.open;

// コンテンツ更新型フィールド
const weeklyItems: WeeklyItem[] = store.weekly_items ?? [];
const diaryEntries: DiaryEntry[] = store.diary ?? [];
const features = store.features ?? [];

// Instagram ハンドル（#70）
const officialSns = store.official_sns ?? null;
const instagramHandle = officialSns?.instagram
  ? officialSns.instagram.replace(/.*instagram\.com\//, '@').replace(/\/$/, '')
  : null;

// 今日の特集メニュー（featured_menu の先頭）
const todaySpecial = store.featured_menu?.[0] ?? null;
const reservationNote = store.owner_reservation_note ?? null;
const liveStockCount = store.live_stock_count ?? weeklyItems.length;
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{store.name}</title>
  <meta name="description" content={heroDesc || `${store.name}（${store.category ?? ''}）${store.address ?? ''}`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;500;700;900&display=swap" rel="stylesheet" />
  <style>
  /* Pattern C 専用スタイル: ライブコンテンツ・明るいベーカリー系デザイン */
  /* ===== Global resets ===== */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
  body { background: #FAF7F1; color: #2A241B; font-family: "Hiragino Kaku Gothic ProN", "Yu Gothic", -apple-system, sans-serif; font-size: 15px; line-height: 1.75; }
  img { max-width: 100%; display: block; }
  a { color: inherit; text-decoration: none; }
  ul { list-style: none; }
  [data-animate] { opacity: 0; transform: translateY(24px); transition: opacity 0.7s cubic-bezier(0.22,1,0.36,1), transform 0.7s cubic-bezier(0.22,1,0.36,1); will-change: opacity, transform; }
  [data-animate].in { opacity: 1; transform: none; }
  .no-js [data-animate] { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) {
    [data-animate] { opacity: 1 !important; transform: none !important; transition: none !important; }
    html { scroll-behavior: auto; }
  }
  .pc-wrap {
    --bg: #FAF7F1;
    --bg-2: #F2EBE0;
    --ink: #1F1A12;
    --terracotta: #C77B5F;
    --terracotta-deep: #9C5538;
    --sage: #7C9472;
    --sage-deep: #4E6B47;
    --soft: #E8C5B3;
    --text: #2A241B;
    --text-soft: #6B5E4D;
    --text-faint: #998A77;
    --pc-line: #E5DCD0;
    font-family: "Hiragino Kaku Gothic ProN", "Yu Gothic", -apple-system, sans-serif;
    background: var(--bg);
    color: #2A241B;
    font-size: 15px;
    line-height: 1.85;
  }
  .pc-wrap a { color: inherit; text-decoration: none; }

  /* ===== Nav ===== */
  .pc-nav {
    position: sticky; top: 0; z-index: 200;
    background: rgba(250,247,241,0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--pc-line);
  }
  .pc-nav-inner {
    max-width: 980px; margin: 0 auto;
    padding: 14px 24px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .pc-brand {
    font-family: "Hiragino Mincho ProN", serif;
    font-size: 18px; font-weight: 600; letter-spacing: 0.05em;
    color: var(--ink);
  }
  .pc-brand .pc-brand-small {
    display: block; font-size: 9px; letter-spacing: 0.2em;
    color: var(--text-faint); font-weight: 500; margin-top: -2px;
  }
  .pc-nav-links {
    display: flex; gap: 22px; font-size: 13px; color: var(--text-soft);
  }
  .pc-nav-links a:hover { color: var(--terracotta); }
  .pc-nav-cta {
    background: var(--ink); color: var(--bg);
    padding: 8px 16px; font-size: 12px; font-weight: 700;
    border-radius: 4px; letter-spacing: 0.04em;
  }

  /* ===== Container ===== */
  .pc-container { max-width: 980px; margin: 0 auto; padding: 0 24px; }

  /* ===== Live status bar ===== */
  .pc-live-bar {
    background: #E8F0E4; border-bottom: 1px solid #C7D4C0; padding: 10px 0;
  }
  .pc-live-bar-inner {
    max-width: 980px; margin: 0 auto; padding: 0 24px;
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 8px; font-size: 13px;
  }
  .pc-live-dot {
    display: inline-block; width: 8px; height: 8px;
    background: var(--sage-deep); border-radius: 50%; margin-right: 6px;
    animation: pc-pulse 2s infinite;
  }
  .pc-live-dot.closed { background: #999; animation: none; }
  @keyframes pc-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(78,107,71,0.6); }
    50% { box-shadow: 0 0 0 6px rgba(78,107,71,0); }
  }
  .pc-live-state { font-weight: 700; color: var(--sage-deep); letter-spacing: 0.04em; }
  .pc-live-state.closed { color: #888; }
  .pc-live-meta { color: var(--text-soft); font-size: 12px; }

  /* ===== Hero / Today's special ===== */
  .pc-hero { padding: 56px 0 64px; }
  .pc-hero-grid {
    display: grid; grid-template-columns: 1fr 1.05fr;
    gap: 48px; align-items: center;
  }
  .pc-hero-eyebrow {
    font-family: "Hiragino Mincho ProN", serif;
    font-style: italic; color: var(--terracotta);
    font-size: 14px; letter-spacing: 0.1em; margin-bottom: 14px;
  }
  .pc-hero h1 {
    font-family: "Hiragino Mincho ProN", serif;
    font-size: 42px; font-weight: 500; line-height: 1.3;
    letter-spacing: 0.02em; margin-bottom: 20px; color: var(--ink);
  }
  .pc-hero-lead {
    font-size: 15px; color: var(--text-soft); line-height: 1.95;
    margin-bottom: 28px; max-width: 460px;
  }
  .pc-hero-stats {
    display: flex; gap: 32px; padding: 20px 0;
    border-top: 1px solid var(--pc-line); border-bottom: 1px solid var(--pc-line);
  }
  .pc-hero-stat .pc-num {
    font-family: "Hiragino Mincho ProN", serif;
    font-size: 28px; font-weight: 500; color: var(--ink); line-height: 1;
  }
  .pc-hero-stat .pc-num .pc-unit { font-size: 13px; color: var(--text-soft); margin-left: 2px; }
  .pc-hero-stat .pc-lbl {
    font-size: 11px; color: var(--text-soft); letter-spacing: 0.08em; margin-top: 6px;
  }
  .pc-hero-img {
    aspect-ratio: 4/5;
    background: radial-gradient(ellipse at 35% 40%, #E5C9A1 0%, #C9914E 40%, #8E5C26 100%);
    border-radius: 6px; position: relative; overflow: hidden;
    box-shadow: 0 30px 60px rgba(0,0,0,0.08);
  }
  .pc-hero-img::before {
    content: '🍽️'; position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 140px;
    filter: drop-shadow(0 12px 20px rgba(0,0,0,0.25));
  }
  .pc-hero-img-tag {
    position: absolute; top: 18px; left: 18px;
    background: var(--bg); color: var(--ink);
    padding: 8px 14px; font-size: 11px; font-weight: 700;
    letter-spacing: 0.12em; border-radius: 999px; text-transform: uppercase;
  }
  .pc-hero-img-cap {
    position: absolute; bottom: 18px; left: 18px; right: 18px;
    background: rgba(255,255,255,0.95); backdrop-filter: blur(6px);
    padding: 14px 16px; border-radius: 4px;
  }
  .pc-hero-img-cap h3 {
    font-family: "Hiragino Mincho ProN", serif;
    font-size: 18px; font-weight: 600; color: var(--ink); margin-bottom: 4px;
  }
  .pc-hero-img-cap .pc-pr {
    font-family: "Hiragino Mincho ProN", serif;
    font-size: 16px; font-weight: 600; color: var(--terracotta-deep);
  }
  .pc-hero-img-cap .pc-desc {
    font-size: 11.5px; color: var(--text-soft); line-height: 1.6; margin-top: 4px;
  }

  /* ===== Section common ===== */
  .pc-section { padding: 64px 0; }
  .pc-section-eyebrow {
    font-family: "Hiragino Mincho ProN", serif; font-style: italic;
    color: var(--terracotta); font-size: 13px; letter-spacing: 0.1em; margin-bottom: 10px;
  }
  .pc-section-title {
    font-family: "Hiragino Mincho ProN", serif; font-size: 28px; font-weight: 500;
    color: var(--ink); margin-bottom: 14px; line-height: 1.4; letter-spacing: 0.02em;
  }
  .pc-section-lead {
    font-size: 14.5px; color: var(--text-soft); max-width: 560px;
    margin-bottom: 36px; line-height: 1.95;
  }

  /* ===== Journal / 日誌 ===== */
  .pc-journal { background: var(--bg-2); }
  .pc-journal-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .pc-journal-card {
    background: var(--bg); border: 1px solid var(--pc-line);
    border-radius: 6px; overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .pc-journal-card:hover { transform: translateY(-2px); box-shadow: 0 18px 32px rgba(0,0,0,0.06); }
  .pc-journal-img {
    aspect-ratio: 4/3;
    background: radial-gradient(ellipse at 40% 50%, #D1B789, #8E6A38);
  }
  .pc-ji-2 { background: radial-gradient(ellipse at 40% 50%, #E8C5B3, #B07A5C); }
  .pc-ji-3 { background: radial-gradient(ellipse at 40% 50%, #C9914E, #6E4621); }
  .pc-journal-body { padding: 18px 20px 22px; }
  .pc-journal-date {
    font-family: ui-monospace, monospace; font-size: 11px;
    color: var(--text-faint); letter-spacing: 0.08em; margin-bottom: 6px;
  }
  .pc-journal-title {
    font-family: "Hiragino Mincho ProN", serif; font-size: 16px; font-weight: 600;
    color: var(--ink); margin-bottom: 8px; line-height: 1.5;
  }
  .pc-journal-excerpt { font-size: 12.5px; color: var(--text-soft); line-height: 1.7; }

  /* ===== Ingredients / 食材 ===== */
  .pc-ingredients-grid {
    display: grid; grid-template-columns: 1.2fr 1fr; gap: 48px; align-items: start;
  }
  .pc-ing-list {
    background: var(--bg); border: 1px solid var(--pc-line);
    border-radius: 6px; padding: 24px 28px;
  }
  .pc-ing-list h4 {
    font-family: "Hiragino Mincho ProN", serif; font-size: 16px; font-weight: 600;
    margin-bottom: 14px; color: var(--ink);
  }
  .pc-ing-row {
    display: grid; grid-template-columns: 1fr auto;
    padding: 10px 0; border-bottom: 1px dashed var(--pc-line); font-size: 13px;
  }
  .pc-ing-row:last-child { border-bottom: none; }
  .pc-ing-name { color: var(--ink); }
  .pc-ing-name .pc-note {
    display: block; font-size: 10.5px; color: var(--text-faint); margin-top: 2px;
  }
  .pc-ing-icon { font-size: 18px; align-self: center; }

  /* ===== Menu ===== */
  .pc-menu-bg { background: var(--bg-2); }
  .pc-menu-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .pc-menu-card {
    background: var(--bg); border-radius: 6px; overflow: hidden; border: 1px solid var(--pc-line);
  }
  .pc-menu-img {
    aspect-ratio: 1/1;
    background: radial-gradient(ellipse at 40% 40%, #D9B47A 0%, #8E6532 100%);
    position: relative;
  }
  .pc-mi-2 { background: radial-gradient(ellipse at 40% 40%, #E5C9A1 0%, #A07A45 100%); }
  .pc-mi-3 { background: radial-gradient(ellipse at 40% 40%, #C9A179 0%, #6E4621 100%); }
  .pc-mi-4 { background: radial-gradient(ellipse at 40% 40%, #E0B17F 0%, #8E5C26 100%); }
  .pc-mi-5 { background: radial-gradient(ellipse at 40% 40%, #D1AF7E 0%, #6E4825 100%); }
  .pc-mi-6 { background: radial-gradient(ellipse at 40% 40%, #DEC093 0%, #957043 100%); }
  .pc-menu-body { padding: 14px 16px 16px; }
  .pc-menu-name {
    font-family: "Hiragino Mincho ProN", serif; font-size: 14.5px; font-weight: 600; color: var(--ink);
  }
  .pc-menu-desc { font-size: 11.5px; color: var(--text-soft); margin-top: 4px; line-height: 1.55; }
  .pc-menu-price {
    font-family: "Hiragino Mincho ProN", serif; font-size: 14px; font-weight: 600;
    color: var(--terracotta-deep); margin-top: 8px;
  }

  /* ===== SNS フィード ===== */
  .pc-sns-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 4px; }
  .pc-sns-cell {
    aspect-ratio: 1/1;
    background: radial-gradient(ellipse at 40% 40%, #C9914E, #6E4621);
    position: relative;
  }
  .pc-sc-2 { background: radial-gradient(ellipse at 40% 40%, #D1B789, #8E6A38); }
  .pc-sc-3 { background: radial-gradient(ellipse at 40% 40%, #E0B17F, #8E5C26); }
  .pc-sc-4 { background: radial-gradient(ellipse at 40% 40%, #C77B5F, #9C5538); }
  .pc-sc-5 { background: radial-gradient(ellipse at 40% 40%, #E8C5B3, #B07A5C); }
  .pc-sc-6 { background: radial-gradient(ellipse at 40% 40%, #D9B47A, #8E6532); }
  .pc-sns-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 16px; }
  .pc-sns-handle { font-size: 12px; color: var(--text-soft); font-family: ui-monospace, monospace; }

  /* ===== Visit ===== */
  .pc-visit-grid {
    display: grid; grid-template-columns: 1.1fr 1fr; gap: 48px; align-items: center;
  }
  .pc-map-mock {
    aspect-ratio: 4/3;
    background:
      linear-gradient(rgba(255,255,255,0.85), rgba(255,255,255,0.85)),
      repeating-linear-gradient(0deg, #DAD3C0 0 1px, transparent 1px 30px),
      repeating-linear-gradient(90deg, #DAD3C0 0 1px, transparent 1px 30px),
      var(--bg);
    border-radius: 6px; border: 1px solid var(--pc-line);
    display: flex; align-items: center; justify-content: center; position: relative;
  }
  .pc-map-pin {
    width: 32px; height: 32px; background: var(--terracotta);
    border-radius: 50% 50% 50% 0; transform: rotate(-45deg);
    box-shadow: 0 8px 20px rgba(199,123,95,0.4); position: relative;
  }
  .pc-map-pin::after {
    content: ""; position: absolute;
    width: 12px; height: 12px; background: var(--bg);
    border-radius: 50%; top: 50%; left: 50%; transform: translate(-50%, -50%);
  }
  .pc-visit-table {
    background: var(--bg); border: 1px solid var(--pc-line); border-radius: 6px; overflow: hidden;
  }
  .pc-visit-row {
    display: grid; grid-template-columns: 100px 1fr;
    padding: 14px 20px; border-bottom: 1px solid var(--pc-line); font-size: 13px;
  }
  .pc-visit-row:last-child { border-bottom: none; }
  .pc-visit-row dt {
    color: var(--text-soft); font-size: 11px; font-weight: 700;
    letter-spacing: 0.06em; align-self: center;
  }
  .pc-visit-row dd { color: var(--ink); }

  /* ===== Newsletter / LINE CTA ===== */
  .pc-nl-section {
    background:
      linear-gradient(135deg, rgba(31,26,18,0.95), rgba(46,38,26,0.9)),
      radial-gradient(ellipse at 30% 40%, #C9914E 0%, #6E4621 60%, #2A1810 100%);
    color: var(--bg); text-align: center; padding: 80px 0;
  }
  .pc-nl-section h2 {
    font-family: "Hiragino Mincho ProN", serif; font-size: 30px; font-weight: 500;
    margin-bottom: 14px; line-height: 1.45; color: #FAF7F1;
  }
  .pc-nl-section p {
    font-size: 14.5px; opacity: 0.85; max-width: 500px;
    margin: 0 auto 30px; line-height: 1.85; color: #FAF7F1;
  }
  .pc-nl-actions { display: flex; justify-content: center; gap: 12px; flex-wrap: wrap; }
  .pc-btn-line {
    background: #06C755; color: #fff;
    padding: 14px 28px; font-size: 14px; font-weight: 700;
    border-radius: 4px; letter-spacing: 0.04em;
  }
  .pc-btn-ghost {
    background: transparent; border: 1.5px solid rgba(255,255,255,0.5);
    color: #FAF7F1; padding: 14px 28px; font-size: 14px; font-weight: 700;
    border-radius: 4px; letter-spacing: 0.04em;
  }
  .pc-btn-primary {
    background: var(--terracotta); color: #fff;
    padding: 14px 28px; font-size: 14px; font-weight: 700;
    border-radius: 4px; letter-spacing: 0.04em;
  }

  /* ===== Responsive ===== */
  @media (max-width: 840px) {
    .pc-hero { padding: 36px 0 48px; }
    .pc-hero-grid { grid-template-columns: 1fr; gap: 28px; }
    .pc-hero h1 { font-size: 30px; }
    .pc-hero-stats { gap: 20px; }
    .pc-journal-grid { grid-template-columns: 1fr; }
    .pc-ingredients-grid { grid-template-columns: 1fr; gap: 28px; }
    .pc-menu-grid { grid-template-columns: 1fr 1fr; }
    .pc-visit-grid { grid-template-columns: 1fr; gap: 28px; }
    .pc-section-title { font-size: 22px; }
    .pc-section { padding: 48px 0; }
    .pc-nl-section { padding: 56px 0; }
    .pc-nl-section h2 { font-size: 22px; }
    .pc-nav-links { display: none; }
    .pc-sns-grid { grid-template-columns: repeat(3, 1fr); }
  }
  </style>
</head>
<body class="no-js">

<div class="pc-wrap">
  {/* ===== Nav ===== */}
  <nav class="pc-nav">
    <div class="pc-nav-inner">
      <div class="pc-brand">
        {store.name}
        {store.category && <span class="pc-brand-small">{store.category.toUpperCase()}</span>}
      </div>
      <div class="pc-nav-links">
        {diaryEntries.length > 0 && <a href="#pc-journal">日誌</a>}
        {weeklyItems.length > 0 && <a href="#pc-ingredients">食材</a>}
        <a href="#pc-menu">メニュー</a>
        <a href="#pc-visit">アクセス</a>
      </div>
      <a class="pc-nav-cta" href={reservationLink} target="_blank" rel="noopener">ご予約</a>
    </div>
  </nav>

  {/* ===== Live status bar ===== */}
  <div class="pc-live-bar">
    <div class="pc-live-bar-inner">
      <div>
        <span class={`pc-live-dot${isOpenToday ? '' : ' closed'}`}></span>
        <span class={`pc-live-state${isOpenToday ? '' : ' closed'}`}>
          {isOpenToday ? '本日 OPEN' : '本日 定休日'}
        </span>
        {isOpenToday && todayHours?.open && (
          <span style="color: var(--text-soft); margin-left: 8px;">
            {todayHours.open}〜{todayHours.close ?? ''}
          </span>
        )}
      </div>
      {hours.length > 0 && (
        <div class="pc-live-meta">{hours[0]}</div>
      )}
    </div>
  </div>

  {/* ===== Hero / Today's special ===== */}
  <div class="pc-hero">
    <div class="pc-container">
      <div class="pc-hero-grid">
        <div>
          <div class="pc-hero-eyebrow">
            <em>Today's Special</em>
            <span id="pc-today-date" style="font-size:11px; opacity:0.7; margin-left:10px; font-family:ui-monospace,monospace;"></span>
          </div>
          <h1>{store.name}</h1>
          {heroDesc && <p class="pc-hero-lead">{heroDesc}</p>}
          {store.stats && store.stats.length > 0 && (
            <div class="pc-hero-stats">
              {store.stats.map((s) => (
                <div class="pc-hero-stat">
                  <div class="pc-num">{s.value}</div>
                  {s.label && <div class="pc-lbl">{s.label}</div>}
                </div>
              ))}
            </div>
          )}
        </div>
        <div class="pc-hero-img">
          <span class="pc-hero-img-tag">本日のおすすめ</span>
          {todaySpecial ? (
            <div class="pc-hero-img-cap">
              <h3>{todaySpecial.name}</h3>
              {todaySpecial.price != null && todaySpecial.price !== '' && (
                <div class="pc-pr">
                  {typeof todaySpecial.price === 'number' ? `¥${todaySpecial.price.toLocaleString()}` : todaySpecial.price}
                </div>
              )}
              {todaySpecial.description && (
                <p class="pc-desc">{todaySpecial.description}</p>
              )}
            </div>
          ) : (
            <div class="pc-hero-img-cap">
              <h3>{store.name}</h3>
              {store.category && <p class="pc-desc">{store.category}</p>}
            </div>
          )}
        </div>
      </div>
    </div>
  </div>

  {/* ===== Journal / 日誌（データある時のみ）===== */}
  {(diaryEntries.length > 0 || store.owner_message) && (
    <div class="pc-section pc-journal" id="pc-journal">
      <div class="pc-container">
        <span class="pc-section-eyebrow"><em>Journal</em></span>
        <h2 class="pc-section-title">店主の日誌。</h2>
        <p class="pc-section-lead">日々のお知らせや季節の情報をお届けします。</p>
        {diaryEntries.length > 0 ? (
          <div class="pc-journal-grid">
            {diaryEntries.slice(0, 3).map((entry, i) => (
              <div class="pc-journal-card">
                <div class={`pc-journal-img${i === 1 ? ' pc-ji-2' : i === 2 ? ' pc-ji-3' : ''}`}></div>
                <div class="pc-journal-body">
                  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
                    {entry.date && <div class="pc-journal-date">{entry.date}</div>}
                    {entry.read_time && <div style="font-size:10px; color:var(--text-faint); font-family:ui-monospace,monospace;">{entry.read_time}</div>}
                  </div>
                  <h3 class="pc-journal-title">{entry.text.slice(0, 40)}{entry.text.length > 40 ? '…' : ''}</h3>
                  <p class="pc-journal-excerpt">{entry.text}</p>
                  {entry.tags && entry.tags.length > 0 && (
                    <div style="display:flex; flex-wrap:wrap; gap:4px; margin-top:10px;">
                      {entry.tags.map(tag => (
                        <span style="font-size:10px; color:var(--terracotta); background:rgba(199,123,95,0.08); padding:2px 7px; border-radius:999px; font-family:'Hiragino Kaku Gothic ProN',sans-serif;">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        ) : store.owner_message ? (
          <div class="pc-journal-grid">
            <div class="pc-journal-card">
              <div class="pc-journal-img"></div>
              <div class="pc-journal-body">
                <div class="pc-journal-date">オーナーより</div>
                <h3 class="pc-journal-title">{store.owner_message.slice(0, 30)}{store.owner_message.length > 30 ? '…' : ''}</h3>
                <p class="pc-journal-excerpt">{store.owner_message}</p>
              </div>
            </div>
          </div>
        ) : null}
      </div>
    </div>
  )}

  {/* ===== Ingredients / 食材（weekly_items データある時のみ）===== */}
  {weeklyItems.length > 0 && (
    <div class="pc-section" id="pc-ingredients">
      <div class="pc-container">
        <div class="pc-ingredients-grid">
          <div>
            <span class="pc-section-eyebrow"><em>Ingredients</em></span>
            <h2 class="pc-section-title">今週入った、<br>食材・おすすめ。</h2>
            <p class="pc-section-lead">入荷した瞬間にお客様にもお知らせ。</p>
            <p style="font-size:12px; color:var(--text-faint); margin-top:8px; font-family:ui-monospace,monospace;">現在 {liveStockCount} 種類が入荷中</p>
          </div>
          <div class="pc-ing-list">
            <h4>今週の情報</h4>
            {weeklyItems.map((item) => (
              <div class="pc-ing-row">
                <div class="pc-ing-name">
                  {item.icon && <span style="margin-right:6px;">{item.icon}</span>}
                  {item.name}
                  {item.status === 'limited' && <span style="font-size:10px; background:#FFF0E0; color:#B85A20; padding:2px 6px; border-radius:3px; margin-left:8px; font-family:'Hiragino Kaku Gothic ProN',sans-serif;">残りわずか</span>}
                  {item.status === 'sold_out' && <span style="font-size:10px; background:#F0F0F0; color:#888; padding:2px 6px; border-radius:3px; margin-left:8px; font-family:'Hiragino Kaku Gothic ProN',sans-serif;">本日完売</span>}
                  {item.note && <span class="pc-note">{item.note}</span>}
                </div>
                <div style="display:flex; flex-direction:column; align-items:flex-end; gap:2px; flex-shrink:0;">
                  {item.origin && <span style="font-size:11px; color:var(--text-faint);">{item.origin}</span>}
                  {item.updated_at && <span style="font-size:10px; color:var(--text-faint); font-family:ui-monospace,monospace;">{item.updated_at}</span>}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  )}

  {/* ===== Menu ===== */}
  {store.featured_menu && store.featured_menu.length > 0 && (
    <div class="pc-section pc-menu-bg" id="pc-menu">
      <div class="pc-container">
        <span class="pc-section-eyebrow"><em>Today's Menu</em></span>
        <h2 class="pc-section-title">本日のメニュー。</h2>
        {budget.length > 0 && <p class="pc-section-lead">予算の目安: {budget.join(' / ')}</p>}
        <div class="pc-menu-grid">
          {store.featured_menu.map((item, i) => {
            const imgClasses = ['', ' pc-mi-2', ' pc-mi-3', ' pc-mi-4', ' pc-mi-5', ' pc-mi-6'];
            const imgClass = `pc-menu-img${imgClasses[i % imgClasses.length]}`;
            return (
              <div class="pc-menu-card">
                <div class={imgClass}></div>
                <div class="pc-menu-body">
                  <div class="pc-menu-name">{item.name}</div>
                  {item.description && <p class="pc-menu-desc">{item.description}</p>}
                  {item.price != null && item.price !== '' && (
                    <div class="pc-menu-price">
                      {typeof item.price === 'number' ? `¥${item.price.toLocaleString()}` : item.price}
                    </div>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  )}

  {/* ===== SNS フィード（Instagram がある場合のみ）===== */}
  {officialSns?.instagram && (
    <div class="pc-section">
      <div class="pc-container">
        <div class="pc-sns-head">
          <div>
            <span class="pc-section-eyebrow"><em>SNS</em></span>
            <h2 class="pc-section-title" style="margin-bottom:0;">毎日の投稿から。</h2>
          </div>
          {instagramHandle && <span class="pc-sns-handle">{instagramHandle}</span>}
        </div>
        <p class="pc-section-lead">日々の入荷・新メニュー・お客様との時間。Instagram でもお届けしています。</p>
        <div class="pc-sns-grid">
          <div class="pc-sns-cell"></div>
          <div class="pc-sns-cell pc-sc-2"></div>
          <div class="pc-sns-cell pc-sc-3"></div>
          <div class="pc-sns-cell pc-sc-4"></div>
          <div class="pc-sns-cell pc-sc-5"></div>
          <div class="pc-sns-cell pc-sc-6"></div>
        </div>
        <div style="text-align:center; margin-top:12px;">
          <a href={officialSns.instagram} target="_blank" rel="noopener noreferrer"
             style="font-size:13px; color:var(--text-soft);">Instagram を見る →</a>
        </div>
      </div>
    </div>
  )}

  {/* ===== Visit ===== */}
  <div class="pc-section" style="background: var(--bg-2);" id="pc-visit">
    <div class="pc-container">
      <div class="pc-visit-grid">
        <div class="pc-map-mock"><div class="pc-map-pin"></div></div>
        <div>
          <span class="pc-section-eyebrow"><em>Visit</em></span>
          <h2 class="pc-section-title">
            {store.nearest_station ? `${store.nearest_station}から。` : 'アクセス。'}
          </h2>
          <dl class="pc-visit-table">
            {store.address && (
              <div class="pc-visit-row">
                <dt>住所</dt>
                <dd>{store.postal_code ? `〒${store.postal_code} ` : ''}{store.address}</dd>
              </div>
            )}
            {store.nearest_station && (
              <div class="pc-visit-row">
                <dt>アクセス</dt>
                <dd>{store.nearest_station}</dd>
              </div>
            )}
            {hours.map((h) => (
              <div class="pc-visit-row">
                <dt>営業時間</dt>
                <dd>{h}</dd>
              </div>
            ))}
            {store.holiday && (
              <div class="pc-visit-row">
                <dt>定休日</dt>
                <dd>{store.holiday}</dd>
              </div>
            )}
            {store.tel && (
              <div class="pc-visit-row">
                <dt>TEL</dt>
                <dd><a href={`tel:${store.tel}`}>{store.tel}</a></dd>
              </div>
            )}
            {store.payment_accepted && (
              <div class="pc-visit-row">
                <dt>支払い</dt>
                <dd>{store.payment_accepted}</dd>
              </div>
            )}
            {store.reservation_url && (
              <div class="pc-visit-row">
                <dt>予約</dt>
                <dd><a href={store.reservation_url} target="_blank" rel="noopener" style="color:var(--terracotta);">オンラインで予約する</a></dd>
              </div>
            )}
            <div class="pc-visit-row">
              <dt>地図</dt>
              <dd><a href={maps} target="_blank" rel="noopener" style="color:var(--terracotta);">Google マップ →</a></dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </div>

  {/* ===== Voices（has_real_name_reviews && review_url）===== */}
  {store.has_real_name_reviews && store.review_url && (
    <div class="pc-section" id="pc-voices">
      <div class="pc-container" style="text-align:center; max-width:700px;">
        <span class="pc-section-eyebrow"><em>Voices</em></span>
        <h2 class="pc-section-title">SNS のお客さまの声。</h2>
        <p class="pc-section-lead">SNS に投稿されたお客様の声です。実際にご来店されたお客様の生の声をご確認いただけます。</p>
        <a href={store.review_url} target="_blank" rel="noopener noreferrer" class="pc-btn-primary" style="display:inline-flex; align-items:center; gap:6px;">
          <img src="https://retty.me/favicon.ico" alt="Retty" width="16" height="16" style="border-radius:3px;" />
          Retty で見る
        </a>
      </div>
    </div>
  )}

  {/* ===== Links（retty_url）===== */}
  {store.retty_url && (
    <div class="pc-section" style="background:var(--bg-2);" id="pc-links">
      <div class="pc-container" style="text-align:center; max-width:700px;">
        <span class="pc-section-eyebrow"><em>Links</em></span>
        <h2 class="pc-section-title">掲載サイト。</h2>
        <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; margin-top:1.5rem;">
          <a href={store.retty_url} target="_blank" rel="noopener noreferrer" class="pc-btn-outline" style="display:inline-flex; align-items:center; gap:6px;">
            <img src="https://retty.me/favicon.ico" alt="Retty" width="16" height="16" style="border-radius:3px;" />
            Retty で見る
          </a>
        </div>
      </div>
    </div>
  )}

  {/* ===== Newsletter / LINE CTA ===== */}
  <div class="pc-nl-section" id="pc-reserve">
    <div class="pc-container">
      <h2>最新情報を、<br>いち早くお届けします。</h2>
      <p>
        {reservationNote || (store.sns?.line
          ? 'LINE 公式アカウントを友だち追加すると、新メニューや営業情報をいち早くお知らせします。'
          : 'ご予約・お問い合わせはこちらからどうぞ。'
        )}
      </p>
      <div class="pc-nl-actions">
        {store.sns?.line ? (
          <>
            <a class="pc-btn-line" href={store.sns.line} target="_blank" rel="noopener">LINE 公式アカウントを友だち追加</a>
            <a class="pc-btn-ghost" href={reservationLink} target="_blank" rel="noopener">ご予約はこちら</a>
          </>
        ) : (
          <a class="pc-btn-primary" href={reservationLink} target="_blank" rel="noopener">ご予約・お問い合わせ</a>
        )}
        {store.tel && (
          <a class="pc-btn-ghost" href={`tel:${store.tel}`}>{store.tel}</a>
        )}
      </div>
    </div>
  </div>
</div>

<!-- ===== Footer ===== -->
<footer style="background:#1F1A12; color:rgba(250,247,241,0.55); padding:48px 0 36px; text-align:center; font-size:12px; line-height:2; font-family:'Hiragino Kaku Gothic ProN',sans-serif; letter-spacing:0.08em;">
  <div style="max-width:1040px; margin:0 auto; padding:0 28px;">
    <div style="font-size:17px; color:#FAF7F1; font-weight:600; letter-spacing:0.12em; margin-bottom:6px;">{store.name}</div>
    {store.address && <div>{store.address}</div>}
    {store.tel && <div>{store.tel}</div>}
    <div style="margin-top:24px; padding-top:20px; border-top:1px solid rgba(250,247,241,0.1); font-size:10px; opacity:0.5; letter-spacing:0.14em;">© 2026 {store.name} · POWERED BY RESTAURANT AGENT</div>
  </div>
</footer>

<script>
  document.body.classList.remove('no-js');
  // 今日の日付を hero に動的表示
  const dateEl = document.getElementById('pc-today-date');
  if (dateEl) {
    const d = new Date();
    const fmt = `${d.getFullYear()}/${String(d.getMonth()+1).padStart(2,'0')}/${String(d.getDate()).padStart(2,'0')}`;
    dateEl.textContent = fmt;
  }
  const animated = Array.from(document.querySelectorAll('[data-animate]'));
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduce || !('IntersectionObserver' in window)) {
    animated.forEach(el => el.classList.add('in'));
  } else {
    const io = new IntersectionObserver((entries, obs) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) { entry.target.classList.add('in'); obs.unobserve(entry.target); }
      });
    }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
    animated.forEach(el => io.observe(el));
  }
</script>

</body>
</html>
