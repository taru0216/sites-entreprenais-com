---
// foodre 店舗HP本体。store を prop で受け、inline style で自己完結的に描画する。
//
// #253: banwaen 水準へデザイン底上げ。すべて store.json 駆動・データ欠落時フォールバックで
// テンプレ汎用性を維持する。将来のカテゴリ別バリアントは「restaurant ベース」(本ファイル +
// BaseLayout のデザインシステム) を差分上書きして足せる構造を意識している。
// アニメーション基盤 (IntersectionObserver フェードイン・ホバートランジション) は
// BaseLayout 側に集約し、本ファイルは data-animate 属性でフックするだけにしている。
import BaseLayout from '../layouts/BaseLayout.astro';
import { UI } from '../lib/i18n';
import {
  formatHours, formatBudget, gmapsUrl, gmapsEmbedUrl,
  deriveStats, hasMenuPhotos, type Store,
} from '../lib/store';

export interface Props { store: Store; }
const { store } = Astro.props;
const ui = UI;
const hours = formatHours(store);
const budget = formatBudget(store);
const maps = gmapsUrl(store);
const mapsEmbed = gmapsEmbedUrl(store);
const photos = [...(store.retty_photos ?? []), ...(store.owner_photos ?? [])];
const heroPhoto = photos[0] ?? null;
const heroDesc = store.description || store.special_info || '';
// #46: reservation_url がない場合は Google マップへのフォールバックを行わない。
// tel あり → 電話 CTA、tel もなし → 予約 CTA 非表示。
const reservationUrl = store.reservation_url ?? null;
// 公式サイト=一次情報のため、第三者評価（レーティング/クチコミ/レビュー）は表示しない。
// rating / review_count / reviews は store.json に残っていても表示には使わない。
const cats = (store.categories && store.categories.length ? store.categories : (store.category ? [store.category] : []));
const stats = deriveStats(store);
const menuPhotoMode = hasMenuPhotos(store);
const features = store.features ?? [];
const hasFeatured = !!(store.featured_menu && store.featured_menu.length > 0);
const menuCount = store.menu?.length ?? 0;
const hasMenuList = menuCount > 0;
---

<BaseLayout title={store.name} siteName={store.name} description={heroDesc || `${store.name}（${store.category ?? ''}）${store.address ?? ''}`}>

  <!-- hero -->
  <section id="hero" class="hero" style={heroPhoto ? `--hero-img:url('${heroPhoto}');` : '--hero-img:none;'}>
    <div class="hero-overlay"></div>
    <div class="hero-content" data-animate="rise">
      {store.category && (
        <p class="hero-eyebrow">{store.category}</p>
      )}
      <h1 class="hero-title">{store.name}</h1>
      {heroDesc && (
        <p class="hero-desc">{heroDesc}</p>
      )}
      <div class="hero-cta">
        <a href="#reservation" class="btn btn-primary">{ui.reserve_button}</a>
        <a href="#menu" class="btn btn-outline">{ui.view_menu}</a>
      </div>
      {stats.length > 0 && (
        <div class="hero-stats">
          {stats.map(s => (
            <div class="stat-badge">
              <span class="stat-value">{s.value}</span>
              {s.label && (<span class="stat-label">{s.label}</span>)}
            </div>
          ))}
        </div>
      )}
    </div>
    <div class="hero-scroll">
      <span>{ui.hero_scroll}</span>
      <span class="hero-scroll-line"></span>
    </div>
  </section>

  <!-- photos -->
  {photos.length > 0 && (
    <section id="photos" class="sec sec-alt">
      <div class="section-inner">
        <h2 class="sec-title" data-animate="rise">{ui.photo_title}</h2>
        <p class="sec-sub" data-animate="rise">PHOTO</p>
        <div class="photo-grid">
          {photos.map((p, i) => (
            <figure class="photo-cell" data-animate="rise" style={`--d:${Math.min(i, 8) * 60}ms`}>
              <img src={p} alt={store.name} loading="lazy" />
            </figure>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- menu / categories -->
  <section id="menu" class="sec">
    <div class="section-inner">
      <h2 class="sec-title" data-animate="rise">{ui.menu_title}</h2>
      <p class="sec-sub" data-animate="rise">MENU</p>

      {hasFeatured ? (
        <>
          <div class={menuPhotoMode ? 'menu-grid menu-grid-photo' : 'menu-grid'}>
            {store.featured_menu!.map((item, i) => (
              <article class="menu-card" data-animate="rise" style={`--d:${Math.min(i, 8) * 60}ms`}>
                {menuPhotoMode && (
                  (item.photo || item.photo_url)
                    ? <div class="menu-card-photo"><img src={item.photo ?? item.photo_url!} alt={item.name} loading="lazy" /></div>
                    : <div class="menu-card-photo menu-card-photo-empty"><span>🍽</span></div>
                )}
                <div class="menu-card-body">
                  <h4 class="menu-card-name">
                    <span>{item.name}</span>
                    {item.price != null && item.price !== '' && (
                      <span class="menu-card-price">{typeof item.price === 'number' ? `${item.price.toLocaleString()}円` : item.price}</span>
                    )}
                  </h4>
                  {item.description && (<p class="menu-card-desc">{item.description}</p>)}
                </div>
              </article>
            ))}
          </div>
          {hasMenuList && (
            <div class="menu-all-link" data-animate="rise">
              <a href={`/foodre/${store.retty_id}/menu/`} class="btn btn-outline">
                すべてのメニューを見る ({menuCount}品)
              </a>
            </div>
          )}
        </>
      ) : (
        <div class="menu-fallback" data-animate="rise">
          {cats.length > 0 && (
            <div class="cat-pills">
              {cats.map(c => (<span class="cat-pill">{c}</span>))}
            </div>
          )}
          {budget.length > 0 && (
            <p class="menu-budget">予算の目安: {budget.join(' / ')}</p>
          )}
          <p class="menu-empty">{ui.no_menu}</p>
          {hasMenuList && (
            <div class="menu-all-link" style="margin-top:1.5rem;">
              <a href={`/foodre/${store.retty_id}/menu/`} class="btn btn-outline">
                すべてのメニューを見る ({menuCount}品)
              </a>
            </div>
          )}
        </div>
      )}
    </div>
  </section>

  <!-- features / こだわり（任意・データ有時のみ） -->
  {features.length > 0 && (
    <section id="features" class="sec sec-alt">
      <div class="section-inner">
        <h2 class="sec-title" data-animate="rise">{ui.features_title}</h2>
        <p class="sec-sub" data-animate="rise">FEATURES</p>
        <p class="sec-lead" data-animate="rise">{ui.features_lead}</p>
        <div class="feature-grid">
          {features.map((f, i) => (
            <article class="feature-card" data-animate="rise" style={`--d:${Math.min(i, 8) * 60}ms`}>
              {f.icon && (<div class="feature-icon">{f.icon}</div>)}
              <h3 class="feature-title">{f.title}</h3>
              {f.body && (<p class="feature-body">{f.body}</p>)}
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!--
    公式サイト=一次情報プラットフォームのため、第三者由来のレビュー（お客さまの声）は
    表示しない。store.json の reviews フィールドは保持するが UI には出さない。
  -->

  <!-- access -->
  <section id="access" class="sec sec-alt">
    <div class="section-inner">
      <h2 class="sec-title" data-animate="rise">{ui.access_title}</h2>
      <p class="sec-sub" data-animate="rise">ACCESS</p>

      <div class="access-grid">
        <div data-animate="rise">
          <h3 class="access-subhead">{ui.access_store_info}</h3>
          <dl class="access-dl">
            <dt>{ui.store_name}</dt>
            <dd>{store.name}</dd>

            {store.category && (<>
              <dt>{ui.store_category}</dt>
              <dd>{store.category}</dd>
            </>)}

            {store.address && (<>
              <dt>{ui.store_address}</dt>
              <dd>{store.postal_code ? `〒${store.postal_code} ` : ''}{store.address}</dd>
            </>)}

            {store.nearest_station && (<>
              <dt>{ui.store_station}</dt>
              <dd>{store.nearest_station}</dd>
            </>)}

            {hours.length > 0 && (<>
              <dt>{ui.store_hours}</dt>
              <dd set:html={hours.join('<br />')} />
            </>)}

            {budget.length > 0 && (<>
              <dt>{ui.store_budget}</dt>
              <dd>{budget.join(' / ')}</dd>
            </>)}

            {store.tel && (<>
              <dt>{ui.store_tel}</dt>
              <dd><a href={`tel:${store.tel}`}>{store.tel}</a></dd>
            </>)}

            {store.payment_accepted && (<>
              <dt>{ui.store_payment}</dt>
              <dd>{store.payment_accepted}</dd>
            </>)}
          </dl>
        </div>

        <div data-animate="rise">
          <h3 class="access-subhead">{ui.access_map}</h3>
          <div class="map-wrap">
            <iframe src={mapsEmbed} title="map" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            <div class="map-link">
              <a href={maps} target="_blank" rel="noopener" class="btn btn-outline btn-sm">{ui.open_in_gmaps}</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- reservation -->
  <section id="reservation" class="sec">
    <div class="section-inner" style="text-align:center;">
      <h2 class="sec-title" data-animate="rise">{ui.reservation_title}</h2>
      <p class="sec-sub" data-animate="rise">RESERVATION</p>
      <p class="reservation-lead" data-animate="rise">{ui.reservation_lead}</p>
      <div class="reservation-cta" data-animate="rise">
        {reservationUrl ? (
          <>
            <a href={reservationUrl} target="_blank" rel="noopener" class="btn btn-primary">{ui.reserve_button}</a>
            {store.tel && (
              <a href={`tel:${store.tel}`} class="btn btn-outline">{store.tel}</a>
            )}
          </>
        ) : store.tel ? (
          <a href={`tel:${store.tel}`} class="btn btn-primary">お電話でご予約ください ({store.tel})</a>
        ) : null}
      </div>
    </div>
  </section>

</BaseLayout>
