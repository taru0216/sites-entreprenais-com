---
// Copyright (C) Retty, Inc.
// foodre Pattern A — ストーリードリブン（カフェ・パン屋・スイーツ系）（#78）
// 川野さん設計: 書体・紙テクスチャ・章立てレイアウトで「物語」を体験させる高質なデザイン
// 元デザイン HTML（01_pattern-A_story-driven.html）ベースで完全差し替え（store.json 変数バインド済み）
//
// 自己完結型ページ: BaseLayout を使わず、直接 <!DOCTYPE html>...<html><head><body> を持つ。
// BaseLayout のヘッダー/フッター/グローバル CSS 競合を根本的に排除する。
import {
  formatHours, formatBudget, gmapsUrl,
  type Store,
} from '../lib/store';

export interface Props { store: Store; }
const { store } = Astro.props;
const hours = formatHours(store);
const budget = formatBudget(store);
const maps = gmapsUrl(store);
// catchphrase → description → special_info の優先順位でヒーロー説明文を選択（#277）
const heroDesc = store.catchphrase || store.description || store.special_info || '';
const reservationLink = store.reservation_url ?? maps;
// #46: reservation_url がない場合は電話 CTA のみ。tel もなければ非表示。
const reservationUrl = store.reservation_url ?? null;
const ownerStory = store.owner_message || store.description || heroDesc || '';
const features = store.features ?? [];
const officialSns = store.official_sns ?? null;
const awards = store.owner_awards ?? [];
const producers = store.owner_producers ?? [];
const courses = store.owner_courses ?? [];
const cancelPolicy = store.owner_cancel_policy || store.cancel_policy || null;

// 公式 SNS リンク構築
const officialSnsLinks: { label: string; href: string }[] = [];
if (officialSns) {
  if (officialSns.instagram) officialSnsLinks.push({ label: 'Instagram で見る', href: officialSns.instagram });
  if (officialSns.tiktok) officialSnsLinks.push({ label: 'TikTok で見る', href: officialSns.tiktok });
  if (officialSns.twitter) officialSnsLinks.push({ label: 'X (Twitter) で見る', href: officialSns.twitter });
  if (officialSns.facebook) officialSnsLinks.push({ label: 'Facebook で見る', href: officialSns.facebook });
}
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{store.name}</title>
  <meta name="description" content={heroDesc || `${store.name}（${store.category ?? ''}）${store.address ?? ''}`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;500;700;900&display=swap" rel="stylesheet" />
  <style>
  /* Pattern A 専用スタイル: 書体=明朝・紙テクスチャ・章立てデザイン */
  /* ===== Global resets ===== */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; }
  body {
    font-family: "Hiragino Mincho ProN", "Yu Mincho", "Georgia", serif;
    color: #2A2620;
    background: #F8F4ED;
    font-size: 15px;
    line-height: 1.95;
    letter-spacing: 0.02em;
  }
  img { max-width: 100%; display: block; }
  a { color: inherit; text-decoration: none; }
  ul { list-style: none; }
  [data-animate] { opacity: 0; transform: translateY(24px); transition: opacity 0.7s cubic-bezier(0.22,1,0.36,1), transform 0.7s cubic-bezier(0.22,1,0.36,1); will-change: opacity, transform; }
  [data-animate].in { opacity: 1; transform: none; }
  .no-js [data-animate] { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) {
    [data-animate] { opacity: 1 !important; transform: none !important; transition: none !important; }
    html { scroll-behavior: auto; }
  }
  /* ===== 変数 ===== */
  .pa-wrap {
    --paper: #F8F4ED;
    --paper-2: #F1EADD;
    --ink: #1A1612;
    --ink-soft: #4A4036;
    --text-faint: #8B7E6E;
    --pa-line: #DDD3C3;
    --gold: #A88B4C;
    --warm: #B65A35;
    font-family: "Hiragino Mincho ProN", "Yu Mincho", "Georgia", serif;
    background: var(--paper);
    color: #2A2620;
    font-size: 15px;
    line-height: 1.95;
    letter-spacing: 0.02em;
  }
  .pa-wrap a { color: inherit; text-decoration: none; }

  /* ===== Nav ===== */
  .pa-nav {
    position: fixed; top: 0; left: 0; right: 0;
    z-index: 200;
    padding: 18px 0;
    background: rgba(248, 244, 237, 0);
    transition: background 0.3s, padding 0.3s;
  }
  .pa-nav.scrolled {
    background: rgba(248, 244, 237, 0.96);
    backdrop-filter: blur(12px);
    padding: 12px 0;
    border-bottom: 1px solid var(--pa-line);
  }
  .pa-nav-inner {
    max-width: 1040px; margin: 0 auto;
    padding: 0 28px;
    display: flex; align-items: center; justify-content: space-between;
  }
  .pa-brand {
    font-size: 18px; font-weight: 400;
    letter-spacing: 0.18em; color: var(--ink);
  }
  .pa-nav-links {
    display: flex; gap: 30px; font-size: 12px;
    letter-spacing: 0.12em; color: var(--ink-soft);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
  }
  .pa-nav-links a:hover { color: var(--warm); }

  /* ===== Container ===== */
  .pa-container { max-width: 1040px; margin: 0 auto; padding: 0 28px; }

  /* ===== Hero ===== */
  .pa-hero {
    position: relative;
    height: 100vh; min-height: 640px; overflow: hidden;
    background:
      linear-gradient(135deg, rgba(26,22,18,0.45) 0%, rgba(26,22,18,0.2) 50%, rgba(26,22,18,0.55) 100%),
      radial-gradient(ellipse at 30% 40%, #8C6A3F 0%, #4A2F18 60%, #1A0E08 100%);
  }
  .pa-hero::after {
    content: "";
    position: absolute; inset: 0;
    background:
      radial-gradient(circle at 70% 30%, rgba(255,210,150,0.15) 0%, transparent 50%),
      radial-gradient(circle at 20% 70%, rgba(255,160,110,0.12) 0%, transparent 50%);
    pointer-events: none;
  }
  .pa-hero-inner {
    position: relative; height: 100%;
    max-width: 1040px; margin: 0 auto; padding: 0 28px;
    display: flex; flex-direction: column;
    justify-content: center; align-items: center;
    text-align: center; color: #F8F4ED;
  }
  .pa-hero-prelude {
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    font-size: 11px; letter-spacing: 0.4em;
    margin-bottom: 28px; opacity: 0.75; text-transform: uppercase;
  }
  .pa-hero h1 {
    font-size: 58px; font-weight: 300;
    letter-spacing: 0.06em; line-height: 1.35; margin-bottom: 26px;
  }
  .pa-hero-sub {
    font-size: 15px; line-height: 2.1;
    max-width: 560px; margin: 0 auto 36px; opacity: 0.85;
  }
  .pa-hero-cta { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .pa-btn-primary {
    display: inline-block;
    background: var(--warm); color: #F8F4ED;
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    padding: 14px 36px; font-size: 13px; font-weight: 700; letter-spacing: 0.18em;
    border-radius: 1px; transition: opacity 0.2s;
  }
  .pa-btn-primary:hover { opacity: 0.85; }
  .pa-btn-outline {
    display: inline-block;
    border: 1px solid rgba(248,244,237,0.5); color: #F8F4ED;
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    padding: 14px 36px; font-size: 13px; font-weight: 700; letter-spacing: 0.18em;
    border-radius: 1px; transition: background 0.2s;
  }
  .pa-btn-outline:hover { background: rgba(248,244,237,0.1); }
  .pa-hero-scroll {
    position: absolute; bottom: 36px; left: 50%;
    transform: translateX(-50%);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    font-size: 10.5px; letter-spacing: 0.3em;
    color: #F8F4ED; opacity: 0.7; text-transform: uppercase;
  }
  .pa-hero-scroll::after {
    content: ""; display: block;
    width: 1px; height: 32px;
    background: rgba(248,244,237,0.6);
    margin: 12px auto 0;
    animation: paScrollLine 2s ease-in-out infinite;
  }
  @keyframes paScrollLine {
    0%, 100% { transform: scaleY(1); }
    50% { transform: scaleY(0.4); transform-origin: top; }
  }

  /* ===== Section common ===== */
  .pa-section { padding: 120px 0; }
  .pa-section-alt { background: var(--paper-2); }
  .pa-chapter-mark {
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    font-size: 10.5px; letter-spacing: 0.35em;
    color: var(--warm); margin-bottom: 28px; text-transform: uppercase;
  }
  .pa-chapter-mark em { font-style: italic; font-family: "Georgia", serif; text-transform: none; color: var(--warm); }
  .pa-disp {
    font-size: 38px; font-weight: 400;
    letter-spacing: 0.04em; line-height: 1.4;
    color: var(--ink); margin-bottom: 32px;
  }
  .pa-body-text { font-size: 15.5px; line-height: 2.15; color: var(--ink-soft); max-width: 560px; }
  .pa-body-text p { margin-bottom: 22px; }
  .pa-body-text p:last-child { margin-bottom: 0; }

  /* ===== Story ===== */
  .pa-story-grid {
    display: grid; grid-template-columns: 1fr 1.15fr;
    gap: 60px; align-items: center;
  }
  .pa-portrait {
    aspect-ratio: 4/5;
    background:
      linear-gradient(135deg, rgba(26,14,8,0.2), rgba(74,30,14,0.1)),
      radial-gradient(ellipse at 50% 45%, #C9966B 0%, #7A4E2E 60%, #2A1810 100%);
    border-radius: 2px; position: relative; overflow: hidden;
  }
  .pa-portrait-emoji {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 120px; opacity: 0.5;
    filter: grayscale(0.3) sepia(0.4);
  }
  .pa-portrait-cap {
    position: absolute; bottom: 24px; left: 24px;
    color: #F8F4ED;
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    font-size: 10.5px; letter-spacing: 0.18em; text-transform: uppercase; opacity: 0.85;
  }
  .pa-portrait-cap strong {
    display: block;
    font-family: "Hiragino Mincho ProN", serif;
    font-size: 18px; letter-spacing: 0.06em; margin-bottom: 4px;
    text-transform: none; opacity: 1;
  }

  /* ===== Source img placeholder ===== */
  .pa-source-img {
    aspect-ratio: 5/4;
    background:
      linear-gradient(rgba(26,14,8,0.1), rgba(26,14,8,0.3)),
      radial-gradient(ellipse at 40% 40%, #BCAD8A 0%, #6E5E3B 60%, #2A2316 100%);
    border-radius: 2px; position: relative;
  }
  .pa-source-img::after {
    content: "🌿"; position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 100px; opacity: 0.5;
  }

  /* ===== Features list ===== */
  .pa-feature-list { margin-top: 24px; border-top: 1px solid var(--pa-line); }
  .pa-feature-row {
    padding: 14px 0; border-bottom: 1px solid var(--pa-line);
    display: grid; grid-template-columns: 40px 1fr; gap: 16px;
    font-size: 13px; align-items: baseline;
  }
  .pa-feature-icon { font-size: 20px; }
  .pa-feature-title { color: var(--ink); font-weight: 500; }
  .pa-feature-body { color: var(--ink-soft); font-size: 12.5px; margin-top: 4px; line-height: 1.7; }

  /* ===== Menu ===== */
  .pa-menu-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  .pa-dish { text-align: left; }
  .pa-dish-img {
    aspect-ratio: 1/1;
    background: radial-gradient(ellipse at 40% 40%, #E5C9A1 0%, #6E4825 100%);
    margin-bottom: 18px; border-radius: 2px;
  }
  .pa-dish-img-2 { background: radial-gradient(ellipse at 40% 40%, #C9966B 0%, #6E3F1E 100%); }
  .pa-dish-img-3 { background: radial-gradient(ellipse at 40% 40%, #B3A582 0%, #4F4A2F 100%); }
  .pa-dish-num {
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    font-size: 10.5px; letter-spacing: 0.18em; color: var(--warm); margin-bottom: 6px;
  }
  .pa-dish h3 {
    font-size: 17px; font-weight: 500; line-height: 1.45;
    margin-bottom: 8px; letter-spacing: 0.04em;
  }
  .pa-dish p { font-size: 13px; color: var(--ink-soft); line-height: 1.85; }
  .pa-dish-price {
    font-size: 14px; color: var(--gold); margin-top: 8px;
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
  }
  .pa-course-info {
    margin-top: 64px; padding: 36px 40px;
    background: var(--paper);
    border-top: 1px solid var(--pa-line);
    border-bottom: 1px solid var(--pa-line);
    display: grid; grid-template-columns: 1fr auto;
    align-items: center; gap: 20px;
  }
  .pa-course-info h4 {
    font-size: 17px; font-weight: 500; letter-spacing: 0.06em; margin-bottom: 6px;
  }
  .pa-course-info p {
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    font-size: 12px; color: var(--text-faint); line-height: 1.7;
  }

  /* ===== Visit ===== */
  .pa-visit-grid {
    display: grid; grid-template-columns: 1fr 1.05fr;
    gap: 60px; align-items: center;
  }
  .pa-visit-table { margin-top: 24px; border-top: 1px solid var(--pa-line); }
  .pa-visit-row {
    display: grid; grid-template-columns: 100px 1fr;
    padding: 16px 0; border-bottom: 1px solid var(--pa-line);
    font-size: 13.5px; align-items: baseline;
  }
  .pa-visit-row dt {
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    font-size: 10.5px; letter-spacing: 0.16em;
    color: var(--text-faint); text-transform: uppercase;
  }
  .pa-visit-row dd { color: var(--ink); letter-spacing: 0.03em; }
  .pa-map-mock {
    aspect-ratio: 4/5;
    background:
      linear-gradient(rgba(255,255,255,0.78), rgba(255,255,255,0.78)),
      repeating-linear-gradient(0deg, #D9CFBC 0 1px, transparent 1px 32px),
      repeating-linear-gradient(90deg, #D9CFBC 0 1px, transparent 1px 32px),
      var(--paper);
    border: 1px solid var(--pa-line);
    position: relative; display: flex; align-items: center; justify-content: center;
  }
  .pa-map-pin {
    width: 30px; height: 30px;
    background: var(--warm);
    border-radius: 50% 50% 50% 0; transform: rotate(-45deg);
    box-shadow: 0 8px 22px rgba(182,90,53,0.4);
    position: relative;
  }
  .pa-map-pin::after {
    content: ""; position: absolute;
    width: 11px; height: 11px; background: var(--paper);
    border-radius: 50%; top: 50%; left: 50%;
    transform: translate(-50%, -50%);
  }
  .pa-gmaps-link {
    display: inline-block;
    border: 1px solid var(--pa-line); color: var(--ink-soft);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    padding: 10px 24px; font-size: 12px; letter-spacing: 0.12em;
    border-radius: 1px; margin-top: 20px;
    transition: all 0.2s;
  }
  .pa-gmaps-link:hover { border-color: var(--warm); color: var(--warm); }

  /* ===== Reservation ===== */
  .pa-reserve-section { text-align: center; }
  .pa-reserve-btn {
    display: inline-block;
    background: var(--ink); color: var(--paper);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    padding: 18px 48px; font-size: 13px; letter-spacing: 0.22em;
    border-radius: 1px; transition: all 0.2s;
  }
  .pa-reserve-btn:hover { background: var(--warm); transform: translateY(-1px); }
  .pa-reserve-tel {
    display: inline-block;
    margin-left: 16px;
    border: 1px solid var(--ink); color: var(--ink);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    padding: 18px 36px; font-size: 13px; letter-spacing: 0.12em;
    border-radius: 1px; transition: all 0.2s;
  }
  .pa-reserve-tel:hover { background: var(--ink); color: var(--paper); }

  /* ===== SNS links ===== */
  .pa-sns-links { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-top: 24px; }
  .pa-sns-btn {
    display: inline-block;
    border: 1px solid var(--pa-line); color: var(--ink-soft);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    padding: 10px 24px; font-size: 12px; letter-spacing: 0.12em;
    border-radius: 1px; transition: all 0.2s;
  }
  .pa-sns-btn:hover { border-color: var(--warm); color: var(--warm); }

  /* ===== Floating CTA ===== */
  .pa-float-cta {
    position: fixed; bottom: 36px; right: 36px;
    background: var(--ink); color: var(--paper);
    font-family: "Hiragino Kaku Gothic ProN", sans-serif;
    padding: 14px 22px; font-size: 12px; letter-spacing: 0.15em;
    border-radius: 999px; z-index: 50;
    box-shadow: 0 12px 28px rgba(26,22,18,0.25);
    transition: all 0.2s;
  }
  .pa-float-cta:hover { background: var(--warm); transform: translateY(-2px); }

  /* ===== Courses ===== */
  .pa-courses-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 24px; margin-top: 40px; }
  .pa-course-card { border: 1px solid var(--pa-line); border-radius: 2px; padding: 28px; }
  .pa-course-name { font-size: 17px; font-weight: 500; letter-spacing: 0.06em; margin-bottom: 8px; color: var(--ink); }
  .pa-course-price { font-size: 14px; color: var(--gold); font-family: "Hiragino Kaku Gothic ProN", sans-serif; letter-spacing: 0.08em; margin-bottom: 12px; }
  .pa-course-desc { font-size: 13px; color: var(--ink-soft); line-height: 1.8; }

  /* ===== Producers ===== */
  .pa-producers-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 28px; margin-top: 40px; }
  .pa-producer-card { display: flex; gap: 16px; }
  .pa-producer-icon { width: 52px; height: 52px; border-radius: 50%; background: var(--paper-2); border: 1px solid var(--pa-line); flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 22px; }
  .pa-producer-name { font-size: 14px; font-weight: 500; color: var(--ink); margin-bottom: 4px; }
  .pa-producer-desc { font-size: 12px; color: var(--text-faint); line-height: 1.7; }

  /* ===== Awards ===== */
  .pa-awards-list { margin-top: 32px; }
  .pa-award-row { display: flex; gap: 24px; padding: 20px 0; border-bottom: 1px solid var(--pa-line); }
  .pa-award-row:first-child { border-top: 1px solid var(--pa-line); }
  .pa-award-year { font-size: 12px; color: var(--gold); font-family: "Hiragino Kaku Gothic ProN", sans-serif; letter-spacing: 0.1em; min-width: 48px; flex-shrink: 0; padding-top: 2px; }
  .pa-award-name { font-size: 15px; font-weight: 500; color: var(--ink); margin-bottom: 4px; }
  .pa-award-desc { font-size: 13px; color: var(--ink-soft); line-height: 1.7; }

  /* ===== Cancel Policy ===== */
  .pa-cancel-box { border: 1px solid var(--pa-line); border-radius: 2px; padding: 24px 28px; margin-top: 24px; }
  .pa-cancel-label { font-size: 11px; letter-spacing: 0.2em; color: var(--text-faint); font-family: "Hiragino Kaku Gothic ProN", sans-serif; margin-bottom: 10px; }
  .pa-cancel-text { font-size: 13px; color: var(--ink-soft); line-height: 1.9; }

  /* ===== Spec ===== */
  .pa-spec-grid { display: flex; gap: 32px; flex-wrap: wrap; margin-top: 16px; }
  .pa-spec-item { display: flex; flex-direction: column; gap: 4px; }
  .pa-spec-label { font-size: 11px; letter-spacing: 0.15em; color: var(--text-faint); font-family: "Hiragino Kaku Gothic ProN", sans-serif; }
  .pa-spec-value { font-size: 15px; color: var(--ink); }

  /* ===== Responsive ===== */
  @media (max-width: 840px) {
    .pa-section { padding: 80px 0; }
    .pa-hero h1 { font-size: 36px; }
    .pa-hero-sub { font-size: 14px; }
    .pa-disp { font-size: 26px; }
    .pa-story-grid, .pa-visit-grid { grid-template-columns: 1fr; gap: 36px; }
    .pa-menu-grid { grid-template-columns: 1fr; }
    .pa-course-info { grid-template-columns: 1fr; text-align: left; }
    .pa-nav-links { display: none; }
    .pa-float-cta { bottom: 16px; right: 16px; padding: 12px 18px; font-size: 11px; }
  }
  </style>
</head>
<body class="no-js">

<div class="pa-wrap">
  {/* ===== Nav ===== */}
  <nav class="pa-nav" id="pa-nav">
    <div class="pa-nav-inner">
      <div class="pa-brand">{store.name}</div>
      <div class="pa-nav-links">
        <a href="#pa-story">ストーリー</a>
        {features.length > 0 && <a href="#pa-features">こだわり</a>}
        <a href="#pa-menu">メニュー</a>
        <a href="#pa-visit">アクセス</a>
      </div>
    </div>
  </nav>

  {/* ===== Hero ===== */}
  <div class="pa-hero">
    <div class="pa-hero-inner">
      {store.category && (
        <div class="pa-hero-prelude">{store.category}{store.address ? ` — ${store.address}` : ''}</div>
      )}
      <h1>{store.name}</h1>
      {heroDesc && <p class="pa-hero-sub">{heroDesc}</p>}
      <div class="pa-hero-cta">
        <a class="pa-btn-primary" href={reservationLink} target="_blank" rel="noopener">ご予約はこちら</a>
        <a class="pa-btn-outline" href="#pa-story">ストーリーを読む</a>
      </div>
    </div>
    <div class="pa-hero-scroll">Scroll</div>
  </div>

  {/* ===== Chapter 01 Story ===== */}
  <div class="pa-section" id="pa-story">
    <div class="pa-container">
      <div class="pa-story-grid">
        <div class="pa-portrait">
          <div class="pa-portrait-emoji">👨‍🍳</div>
          <div class="pa-portrait-cap">
            <strong>{store.name}</strong>
            CHEF / OWNER
          </div>
        </div>
        <div>
          <div class="pa-chapter-mark"><em>Chapter 01 ・</em> 店主の物語</div>
          <h2 class="pa-disp">{store.name}について</h2>
          {ownerStory ? (
            <div class="pa-body-text"><p>{ownerStory}</p></div>
          ) : (
            <div class="pa-body-text">
              <p>{store.category ? `${store.category}専門の` : ''}{store.name}へようこそ。{store.address ? `${store.address}にて` : ''}ご来店をお待ちしております。</p>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>

  {/* ===== Chapter 02 Features / こだわり（データある時のみ）===== */}
  {features.length > 0 && (
    <div class="pa-section pa-section-alt" id="pa-features">
      <div class="pa-container">
        <div style="display:grid; grid-template-columns: 1.15fr 1fr; gap: 60px; align-items: center;">
          <div>
            <div class="pa-chapter-mark"><em>Chapter 02 ・</em> こだわり</div>
            <h2 class="pa-disp">私たちが大切にすること。</h2>
            <div class="pa-feature-list">
              {features.map((f) => (
                <div class="pa-feature-row">
                  <div class="pa-feature-icon">{f.icon ?? '●'}</div>
                  <div>
                    <div class="pa-feature-title">{f.title}</div>
                    {f.body && <p class="pa-feature-body">{f.body}</p>}
                  </div>
                </div>
              ))}
            </div>
          </div>
          <div class="pa-source-img"></div>
        </div>
      </div>
    </div>
  )}

  {/* ===== Chapter 03 Menu ===== */}
  <div class="pa-section" id="pa-menu">
    <div class="pa-container">
      <div style="text-align: center; margin-bottom: 60px;">
        <div class="pa-chapter-mark"><em>Chapter 03 ・</em> メニュー</div>
        <h2 class="pa-disp">おすすめのメニュー。</h2>
        {budget.length > 0 && (
          <p style="font-family:'Hiragino Kaku Gothic ProN',sans-serif; font-size:13px; color:var(--text-faint);">予算の目安: {budget.join(' / ')}</p>
        )}
      </div>
      {store.featured_menu && store.featured_menu.length > 0 ? (
        <>
          <div class="pa-menu-grid">
            {store.featured_menu.slice(0, 3).map((item, i) => (
              <div class="pa-dish">
                <div class={`pa-dish-img${i === 1 ? ' pa-dish-img-2' : i === 2 ? ' pa-dish-img-3' : ''}`}></div>
                <div class="pa-dish-num">— {String(i + 1).padStart(2, '0')} —</div>
                <h3>{item.name}</h3>
                {item.description && <p>{item.description}</p>}
                {item.price != null && item.price !== '' && (
                  <div class="pa-dish-price">
                    {typeof item.price === 'number' ? `¥${item.price.toLocaleString()}` : item.price}
                  </div>
                )}
              </div>
            ))}
          </div>
          {store.featured_menu.length > 3 && (
            <div class="pa-course-info">
              <div>
                <h4>その他のメニュー（全 {store.featured_menu.length} 品）</h4>
                <p>さらに豊富なメニューをご用意しております。詳しくはお問い合わせください。</p>
              </div>
            </div>
          )}
        </>
      ) : (
        <p style="text-align:center; color:var(--text-faint); padding:3rem 0; font-family:'Hiragino Kaku Gothic ProN',sans-serif;">メニューは準備中です。お電話でお問い合わせください。</p>
      )}
    </div>
  </div>

  {/* ===== Chapter 04 Visit ===== */}
  <div class="pa-section" id="pa-visit">
    <div class="pa-container">
      <div class="pa-visit-grid">
        <div>
          <div class="pa-chapter-mark"><em>Chapter 04 ・</em> 訪れる</div>
          <h2 class="pa-disp">{store.nearest_station ? `${store.nearest_station}から。` : 'アクセス。'}</h2>
          {store.address && <div class="pa-body-text"><p>{store.address}</p></div>}
          <dl class="pa-visit-table">
            {store.address && (
              <div class="pa-visit-row">
                <dt>Address</dt>
                <dd>{store.postal_code ? `〒${store.postal_code} ` : ''}{store.address}</dd>
              </div>
            )}
            {store.nearest_station && (
              <div class="pa-visit-row">
                <dt>Access</dt>
                <dd>{store.nearest_station}</dd>
              </div>
            )}
            {hours.map((h) => (
              <div class="pa-visit-row">
                <dt>Open</dt>
                <dd>{h}</dd>
              </div>
            ))}
            {store.holiday && (
              <div class="pa-visit-row">
                <dt>定休日</dt>
                <dd>{store.holiday}</dd>
              </div>
            )}
            {store.tel && (
              <div class="pa-visit-row">
                <dt>TEL</dt>
                <dd><a href={`tel:${store.tel}`}>{store.tel}</a></dd>
              </div>
            )}
            {store.payment_accepted && (
              <div class="pa-visit-row">
                <dt>Payment</dt>
                <dd>{store.payment_accepted}</dd>
              </div>
            )}
          </dl>
        </div>
        <div>
          <div class="pa-map-mock"><div class="pa-map-pin"></div></div>
          <div style="text-align:center;">
            <a href={maps} target="_blank" rel="noopener" class="pa-gmaps-link">Google マップで見る →</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  {/* ===== Reservation ===== */}
  <div class="pa-section pa-section-alt pa-reserve-section" id="pa-reserve">
    <div class="pa-container">
      <div class="pa-chapter-mark"><em>Reservation ・</em> ご予約</div>
      <h2 class="pa-disp">ご予約をお待ちしております。</h2>
      <div class="pa-body-text" style="margin: 0 auto 36px; text-align:center; max-width:540px;">
        {store.reservation_url ? (
          <p>オンラインフォームまたはお電話にてご予約を承っております。</p>
        ) : store.tel ? (
          <p>お電話にてご予約を承っております。</p>
        ) : (
          <p>お気軽にお問い合わせください。</p>
        )}
      </div>
      <div>
        {store.reservation_url && (
          <a class="pa-reserve-btn" href={store.reservation_url} target="_blank" rel="noopener">RESERVE ONLINE</a>
        )}
        {store.tel && (
          <a class={store.reservation_url ? 'pa-reserve-tel' : 'pa-reserve-btn'} href={`tel:${store.tel}`}>{store.tel}</a>
        )}
      </div>
      {store.retty_url && (
        <p style="margin-top:32px; font-size:12px; color:var(--text-faint); font-family:'Hiragino Kaku Gothic ProN',sans-serif;">
          <a href={store.retty_url} target="_blank" rel="noopener" style="color:var(--text-faint);">Retty のクチコミを見る →</a>
        </p>
      )}
    </div>
  </div>

  {/* ===== Courses（オーナー設定コース）===== */}
  {courses.length > 0 && (
    <div class="pa-section" id="pa-courses">
      <div class="pa-container">
        <div class="pa-chapter-mark"><em>Chapter ・</em> コース</div>
        <h2 class="pa-disp">ご用意しているコース。</h2>
        <div class="pa-courses-grid">
          {courses.map(course => (
            <div class="pa-course-card">
              <div class="pa-course-name">{course.name}</div>
              {course.price && <div class="pa-course-price">{typeof course.price === 'number' ? `¥${course.price.toLocaleString()}` : course.price}</div>}
              {course.description && <p class="pa-course-desc">{course.description}</p>}
            </div>
          ))}
        </div>
        {cancelPolicy && (
          <div class="pa-cancel-box">
            <div class="pa-cancel-label">キャンセルポリシー</div>
            <p class="pa-cancel-text">{cancelPolicy}</p>
          </div>
        )}
      </div>
    </div>
  )}

  {/* ===== Producers（仕入れ先・生産者）===== */}
  {producers.length > 0 && (
    <div class="pa-section pa-section-alt" id="pa-producers">
      <div class="pa-container">
        <div class="pa-chapter-mark"><em>Chapter ・</em> 生産者</div>
        <h2 class="pa-disp">信頼する生産者の皆さん。</h2>
        <div class="pa-producers-grid">
          {producers.map(producer => (
            <div class="pa-producer-card">
              <div class="pa-producer-icon">🌾</div>
              <div>
                <div class="pa-producer-name">{producer.name}</div>
                {producer.description && <p class="pa-producer-desc">{producer.description}</p>}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  {/* ===== Awards（受賞歴）===== */}
  {awards.length > 0 && (
    <div class="pa-section" id="pa-awards">
      <div class="pa-container">
        <div class="pa-chapter-mark"><em>Chapter ・</em> 受賞・掲載</div>
        <h2 class="pa-disp">実績と評価。</h2>
        <div class="pa-awards-list">
          {awards.map(award => (
            <div class="pa-award-row">
              {award.year && <div class="pa-award-year">{award.year}</div>}
              <div>
                <div class="pa-award-name">{award.name}</div>
                {award.description && <p class="pa-award-desc">{award.description}</p>}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  {/* ===== Spec（席数・ドレスコード）===== */}
  {(store.spec?.capacity || store.spec?.dress_code) && (
    <div class="pa-section pa-section-alt" id="pa-spec">
      <div class="pa-container">
        <div class="pa-chapter-mark"><em>Chapter ・</em> 設備・情報</div>
        <h2 class="pa-disp">ご利用にあたって。</h2>
        <div class="pa-spec-grid">
          {store.spec?.capacity && (
            <div class="pa-spec-item">
              <span class="pa-spec-label">座席数</span>
              <span class="pa-spec-value">{store.spec.capacity}席</span>
            </div>
          )}
          {store.spec?.dress_code && (
            <div class="pa-spec-item">
              <span class="pa-spec-label">ドレスコード</span>
              <span class="pa-spec-value">{store.spec.dress_code}</span>
            </div>
          )}
        </div>
        {cancelPolicy && courses.length === 0 && (
          <div class="pa-cancel-box">
            <div class="pa-cancel-label">キャンセルポリシー</div>
            <p class="pa-cancel-text">{cancelPolicy}</p>
          </div>
        )}
      </div>
    </div>
  )}

  {/* ===== SNS / official（データある時のみ）===== */}
  {officialSnsLinks.length > 0 && (
    <div class="pa-section" style="text-align:center;">
      <div class="pa-container">
        <div class="pa-chapter-mark"><em>Official ・</em> 公式 SNS</div>
        <h2 class="pa-disp">公式アカウント。</h2>
        <div class="pa-sns-links">
          {officialSnsLinks.map(link => (
            <a class="pa-sns-btn" href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a>
          ))}
        </div>
      </div>
    </div>
  )}

  {/* ===== Voices（has_real_name_reviews && review_url）===== */}
  {store.has_real_name_reviews && store.review_url && (
    <div class="pa-section pa-section-alt" style="text-align:center;" id="pa-voices">
      <div class="pa-container">
        <div class="pa-chapter-mark"><em>Voices ・</em> お客様の声</div>
        <h2 class="pa-disp">SNS のお客さまの声。</h2>
        <div class="pa-body-text" style="margin:0 auto 2rem; text-align:center; max-width:480px;">
          <p>SNS に投稿されたお客様の声です。実際にご来店されたお客様の生の声をご確認いただけます。</p>
        </div>
        <a href={store.review_url} target="_blank" rel="noopener noreferrer" class="pa-btn-outline" style="display:inline-flex; align-items:center; gap:6px;">
          <img src="https://retty.me/favicon.ico" alt="Retty" width="16" height="16" style="border-radius:3px;" />
          Retty で見る
        </a>
      </div>
    </div>
  )}

  {/* ===== Links（retty_url）===== */}
  {store.retty_url && (
    <div class="pa-section" style="text-align:center;" id="pa-links">
      <div class="pa-container">
        <div class="pa-chapter-mark"><em>Links ・</em> 掲載サイト</div>
        <h2 class="pa-disp">掲載サイト。</h2>
        <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; margin-top:2rem;">
          <a href={store.retty_url} target="_blank" rel="noopener noreferrer" class="pa-btn-outline" style="display:inline-flex; align-items:center; gap:6px;">
            <img src="https://retty.me/favicon.ico" alt="Retty" width="16" height="16" style="border-radius:3px;" />
            Retty で見る
          </a>
        </div>
      </div>
    </div>
  )}
</div>

{/* ===== Floating CTA ===== */}
<a class="pa-float-cta" href={reservationLink} target="_blank" rel="noopener">Reserve</a>

<script>
  // Pattern A nav scroll transparency
  const nav = document.getElementById('pa-nav');
  if (nav) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 80) nav.classList.add('scrolled');
      else nav.classList.remove('scrolled');
    });
  }
</script>

<!-- ===== Footer ===== -->
<footer style="background:#1A1612; color:rgba(248,244,237,0.6); padding:56px 0 40px; text-align:center; font-size:12px; line-height:2; font-family:'Hiragino Kaku Gothic ProN',sans-serif; letter-spacing:0.08em;">
  <div style="max-width:1040px; margin:0 auto; padding:0 28px;">
    <div style="font-family:'Hiragino Mincho ProN',serif; font-size:18px; color:#F8F4ED; font-weight:300; letter-spacing:0.2em; margin-bottom:8px;">{store.name}</div>
    {store.address && <div>{store.address}</div>}
    {store.tel && <div>{store.tel}</div>}
    <div style="margin-top:28px; padding-top:24px; border-top:1px solid rgba(248,244,237,0.12); font-size:10px; opacity:0.55; letter-spacing:0.16em;">© 2026 {store.name} · POWERED BY RESTAURANT AGENT</div>
  </div>
</footer>

<script>
  document.body.classList.remove('no-js');
  const animated = Array.from(document.querySelectorAll('[data-animate]'));
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduce || !('IntersectionObserver' in window)) {
    animated.forEach(el => el.classList.add('in'));
  } else {
    const io = new IntersectionObserver((entries, obs) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) { entry.target.classList.add('in'); obs.unobserve(entry.target); }
      });
    }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
    animated.forEach(el => io.observe(el));
  }
</script>

</body>
</html>
