---
// foodre BaseLayout — banwaen ダークテーマを汎用化（is:global で確実にスタイルを当てる）
//
// #253: restaurant 共通デザインシステムを本レイアウトの is:global に集約した。
// ボタン / セクション / ヒーロー / 各種グリッド・カードの見た目、タイポ階層、縦リズム、
// そしてアニメーション基盤（IntersectionObserver フェードイン・ホバートランジション）を
// ここに一元化している。業態別バリアントは将来このデザインシステムを差分上書きして足せる。
import { UI } from '../lib/i18n';

export interface Props {
  title: string;
  siteName: string;
  description?: string;
}
const { title, siteName, description = '' } = Astro.props;
const ui = UI;
const homeHref = '/foodre/';
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | {siteName}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;500;700;900&display=swap" rel="stylesheet" />

  <!--
    CRITICAL: <style is:global>。Astro の scoped <style> は <slot /> で差し込まれた
    別コンポーネント(RestaurantPage)の要素には scope 属性が乗らず CSS が当たらない
    （海士町で実証した不具合）。is:global + プレーンセレクタで全要素に確実に適用する。
  -->
  <style is:global>
    :root {
      --black: #000;
      --white: #fff;
      --orange: #f7970b;
      --orange-soft: #ffb347;
      --blue: #2d88d9;
      --gray: #1a1a1a;
      --gray-light: #333;
      --header-height: 64px;
      /* 縦リズムのトークン化（#253 P2-9）: コンテンツ希薄時でも間延びしないレンジ */
      --sec-pad: clamp(4rem, 9vw, 7rem);
      --max-w: 1100px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--black); color: var(--white);
      font-family: 'Noto Serif JP', serif; line-height: 1.8;
      letter-spacing: 0.02em;
      min-height: 100vh; display: flex; flex-direction: column;
    }
    a { color: var(--orange); text-decoration: none; }
    a:hover { text-decoration: underline; }
    section[id] { scroll-margin-top: calc(var(--header-height) + 8px); }

    /* ---- header ---- */
    header {
      background: var(--gray); border-bottom: 2px solid var(--orange);
      padding: 0 1.5rem; position: sticky; top: 0; z-index: 100;
    }
    .header-inner {
      max-width: var(--max-w); margin: 0 auto; display: flex;
      align-items: center; justify-content: space-between; height: var(--header-height);
    }
    .site-title {
      font-size: 1.4rem; font-weight: 700; color: var(--orange);
      white-space: nowrap; flex-shrink: 0; overflow: hidden; text-overflow: ellipsis;
    }
    .site-title a { color: inherit; }
    .header-right { display: flex; align-items: center; gap: 1.5rem; }
    .main-nav { display: flex; align-items: center; gap: 1.5rem; }
    .main-nav a {
      color: var(--white); font-size: 0.9rem; padding: 0.25rem 0;
      border-bottom: 2px solid transparent; transition: border-color 0.2s, color 0.2s; white-space: nowrap;
    }
    .main-nav a:hover, .main-nav a.active {
      color: var(--orange); border-bottom-color: var(--orange); text-decoration: none;
    }
    .hamburger {
      display: none; flex-direction: column; gap: 5px;
      background: none; border: none; cursor: pointer; padding: 0.4rem; flex-shrink: 0;
    }
    .hamburger span { display: block; width: 24px; height: 2px; background: var(--white); transition: transform 0.25s, opacity 0.25s; }
    .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
    .mobile-nav {
      display: none; position: fixed; top: var(--header-height); left: 0; right: 0;
      background: var(--gray); border-bottom: 2px solid var(--orange);
      padding: 1rem 1.5rem; flex-direction: column; gap: 0; z-index: 99;
    }
    .mobile-nav.open { display: flex; }
    .mobile-nav a { color: var(--white); font-size: 1rem; padding: 0.85rem 0; border-bottom: 1px solid #2a2a2a; display: block; }
    .mobile-nav a:hover { color: var(--orange); text-decoration: none; }
    main { flex: 1; width: 100%; }
    .spa-main .section-inner { max-width: var(--max-w); margin: 0 auto; padding: 0 1.5rem; }

    /* ---- buttons（共通デザインシステム） ---- */
    .btn {
      display: inline-block; font-weight: 700; padding: 0.85rem 2.5rem;
      border-radius: 4px; font-size: 1rem; letter-spacing: 0.05em;
      transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease, color 0.18s ease;
    }
    .btn:hover { text-decoration: none; transform: translateY(-2px); }
    .btn-sm { padding: 0.5rem 1.25rem; font-size: 0.9rem; }
    .btn-primary { background: var(--orange); color: #000; box-shadow: 0 6px 18px rgba(247,151,11,0.25); }
    .btn-primary:hover { box-shadow: 0 10px 26px rgba(247,151,11,0.4); background: var(--orange-soft); }
    .btn-outline { border: 2px solid var(--orange); color: var(--orange); }
    .btn-outline:hover { background: rgba(247,151,11,0.12); }
    .btn-ghost { border: 2px solid #555; color: #ccc; }
    .btn-ghost:hover { border-color: #888; color: #fff; }

    /* ---- sections / タイポ階層（#253 P2-8） ---- */
    .sec { padding: var(--sec-pad) 0; background: #000; }
    .sec-alt { background: #050505; }
    .sec-title {
      font-size: clamp(1.8rem, 4.5vw, 2.6rem); font-weight: 900; color: var(--orange);
      text-align: center; margin-bottom: 0.35rem; letter-spacing: 0.06em; line-height: 1.2;
    }
    .sec-sub {
      text-align: center; color: #777; font-size: 0.8rem;
      letter-spacing: 0.4em; text-transform: uppercase; margin-bottom: 3rem;
    }
    .sec-lead { text-align: center; color: #bbb; font-size: 1rem; margin: -1.5rem auto 3rem; max-width: 640px; }

    /* ---- hero ---- */
    .hero {
      position: relative; min-height: calc(100vh - var(--header-height));
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      text-align: center; padding: 4rem 1.5rem; overflow: hidden;
      background: var(--hero-img, none) center/cover no-repeat, linear-gradient(180deg, #0a0a0a 0%, #000 100%);
      background-blend-mode: normal;
    }
    /* オーバーレイ強化（#253 P0-2）: 下方向グラデ + 中央ビネットで店名のコントラスト確保 */
    .hero-overlay {
      position: absolute; inset: 0; z-index: 0; pointer-events: none;
      background:
        radial-gradient(ellipse at center, rgba(0,0,0,0.35) 0%, rgba(0,0,0,0.72) 100%),
        linear-gradient(180deg, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.3) 40%, rgba(0,0,0,0.85) 100%);
    }
    .hero-content { position: relative; z-index: 1; max-width: 820px; }
    .hero-eyebrow {
      font-size: 0.95rem; color: #ddd; letter-spacing: 0.32em; margin-bottom: 1rem;
      text-transform: uppercase; text-shadow: 0 1px 8px rgba(0,0,0,0.8);
    }
    .hero-title {
      font-size: clamp(2.6rem, 9vw, 5rem); font-weight: 900; color: #fff; line-height: 1.12;
      margin-bottom: 1.1rem; text-shadow: 0 2px 24px rgba(0,0,0,0.85), 0 0 2px rgba(0,0,0,0.6);
    }
    .hero-rating { color: #fff; margin-bottom: 1.1rem; font-size: 1.05rem; text-shadow: 0 1px 8px rgba(0,0,0,0.8); }
    .hero-rating-star { color: var(--orange); font-weight: 700; }
    .hero-rating-count { color: #ccc; margin-left: 0.6rem; font-size: 0.9rem; }
    .hero-desc {
      font-size: clamp(1rem, 2vw, 1.15rem); color: #eee; margin-bottom: 2.4rem; line-height: 1.95;
      text-shadow: 0 1px 10px rgba(0,0,0,0.85); max-width: 660px; margin-left: auto; margin-right: auto;
    }
    .hero-cta { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
    /* KPI スタッツバッジ（#253 P0-1） */
    .hero-stats { display: flex; gap: clamp(1.5rem, 5vw, 3.5rem); justify-content: center; flex-wrap: wrap; margin-top: 2.8rem; }
    .stat-badge { display: flex; flex-direction: column; align-items: center; min-width: 80px; }
    .stat-value { font-size: clamp(1.8rem, 5vw, 2.6rem); font-weight: 900; color: var(--orange); line-height: 1.1; text-shadow: 0 2px 14px rgba(0,0,0,0.7); }
    .stat-label { font-size: 0.8rem; color: #ddd; letter-spacing: 0.1em; margin-top: 0.3rem; text-shadow: 0 1px 6px rgba(0,0,0,0.8); }
    .hero-scroll {
      position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%); z-index: 1;
      color: #bbb; font-size: 0.75rem; letter-spacing: 0.2em;
      display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
    }
    .hero-scroll-line { display: block; width: 1px; height: 32px; background: linear-gradient(to bottom, #bbb, transparent); animation: scroll-pulse 2s ease-in-out infinite; }
    @keyframes scroll-pulse { 0%,100% { opacity: 0.3; transform: scaleY(0.6); } 50% { opacity: 1; transform: scaleY(1); } }

    /* ---- photo grid（#253 P1-5: トリミング統一 aspect-ratio + object-fit:cover） ---- */
    .photo-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1rem; }
    .photo-cell { aspect-ratio: 4 / 3; border-radius: 8px; overflow: hidden; border: 1px solid #222; background: #111; }
    .photo-cell img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s ease; }
    .photo-cell:hover img { transform: scale(1.06); }

    /* ---- menu ---- */
    .menu-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }
    .menu-grid-photo { grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); }
    .menu-card { background: #111; border: 1px solid #222; border-radius: 10px; overflow: hidden; transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease; }
    .menu-card:hover { transform: translateY(-4px); border-color: var(--orange); box-shadow: 0 12px 30px rgba(0,0,0,0.5); }
    .menu-card-photo { aspect-ratio: 4 / 3; overflow: hidden; background: #0a0a0a; }
    .menu-card-photo img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s ease; }
    .menu-card:hover .menu-card-photo img { transform: scale(1.07); }
    .menu-card-photo-empty { display: flex; align-items: center; justify-content: center; color: #333; font-size: 2.5rem; }
    .menu-card-body { padding: 1.4rem; }
    .menu-card-name { color: var(--orange); margin-bottom: 0.5rem; font-size: 1.05rem; display: flex; justify-content: space-between; align-items: baseline; gap: 0.75rem; }
    .menu-card-price { font-size: 0.9rem; color: var(--orange-soft); white-space: nowrap; }
    .menu-card-desc { color: #bbb; font-size: 0.9rem; line-height: 1.7; }
    .menu-fallback { text-align: center; }
    .cat-pills { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.6rem; margin-bottom: 2rem; }
    .cat-pill { background: #1a1a1a; border: 1px solid var(--orange); color: var(--orange); padding: 0.35rem 1rem; border-radius: 999px; font-size: 0.9rem; transition: background 0.2s, color 0.2s; }
    .cat-pill:hover { background: var(--orange); color: #000; }
    .menu-budget { color: #ddd; font-size: 1rem; }
    .menu-empty { color: #666; margin-top: 1.5rem; }

    /* ---- features grid（#253 P1-4） ---- */
    .feature-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.25rem; }
    .feature-card { background: #111; border: 1px solid #222; border-radius: 10px; padding: 2rem 1.6rem; transition: transform 0.2s ease, border-color 0.2s ease; }
    .feature-card:hover { transform: translateY(-4px); border-color: var(--orange); }
    .feature-icon { font-size: 2rem; margin-bottom: 0.9rem; line-height: 1; }
    .feature-title { color: #fff; font-size: 1.15rem; font-weight: 700; margin-bottom: 0.6rem; }
    .feature-body { color: #aaa; font-size: 0.92rem; line-height: 1.8; }

    /* ---- reviews（#253 P1-6） ---- */
    .review-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem; }
    .review-card { background: #0c0c0c; border: 1px solid #222; border-left: 3px solid var(--orange); border-radius: 8px; padding: 1.8rem 1.6rem; }
    .review-stars { color: var(--orange); letter-spacing: 0.15em; margin-bottom: 0.7rem; }
    .review-body { color: #ddd; font-size: 0.95rem; line-height: 1.9; }
    .review-author { color: #888; font-size: 0.85rem; margin-top: 1rem; font-style: normal; }

    /* ---- access ---- */
    .access-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 3rem; align-items: start; }
    .access-subhead { font-size: 1.1rem; color: #aaa; margin-bottom: 1.5rem; border-left: 3px solid var(--orange); padding-left: 0.75rem; }
    .access-dl { display: grid; grid-template-columns: auto 1fr; gap: 0.75rem 1.5rem; }
    .access-dl dt { color: #666; white-space: nowrap; font-size: 0.9rem; }
    .access-dl dd { color: #ddd; font-size: 0.95rem; }
    .map-wrap { border: 1px solid #222; border-radius: 8px; overflow: hidden; background: #111; }
    .map-wrap iframe { width: 100%; height: 320px; border: 0; display: block; filter: grayscale(0.2) contrast(1.1); }
    .map-link { padding: 1rem; text-align: center; }

    /* ---- reservation ---- */
    .reservation-lead { color: #bbb; max-width: 560px; margin: 0 auto 2.5rem; line-height: 1.95; font-size: 0.98rem; }
    .reservation-cta { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

    /* ---- footer ---- */
    footer { background: var(--gray); border-top: 1px solid var(--gray-light); padding: 2.5rem 1.5rem; font-size: 0.85rem; color: #888; }
    footer .footer-inner { max-width: var(--max-w); margin: 0 auto; text-align: center; }
    footer a { color: #888; margin: 0 0.5rem; }
    footer a:hover { color: var(--orange); }

    /* ---- アニメーション基盤（#253 P1-P2: スクロール連動フェードイン） ---- */
    /* data-animate 要素は初期非表示。IntersectionObserver で .in が付くと現れる。
       JS 無効環境や reduce-motion では即表示にフォールバックして可読性を担保する。 */
    [data-animate] { opacity: 0; transform: translateY(24px); transition: opacity 0.7s cubic-bezier(0.22,1,0.36,1), transform 0.7s cubic-bezier(0.22,1,0.36,1); transition-delay: var(--d, 0ms); will-change: opacity, transform; }
    [data-animate].in { opacity: 1; transform: none; }
    .no-js [data-animate] { opacity: 1; transform: none; }
    @media (prefers-reduced-motion: reduce) {
      [data-animate] { opacity: 1 !important; transform: none !important; transition: none !important; }
      .hero-scroll-line { animation: none; }
      html { scroll-behavior: auto; }
    }

    @media (max-width: 768px) {
      .main-nav { display: none; }
      .hamburger { display: flex; }
      .access-grid { gap: 2rem; }
      .hero-stats { gap: 1.5rem; }
    }
  </style>
</head>
<body class="no-js">
  <header>
    <div class="header-inner">
      <div class="site-title"><a href={homeHref}>{siteName}</a></div>
      <div class="header-right">
        <nav class="main-nav">
          <a href="#menu">{ui.nav_menu}</a>
          <a href="#access">{ui.nav_access}</a>
          <a href="#reservation">{ui.nav_reservation}</a>
          <a href={homeHref}>{ui.back_to_list}</a>
        </nav>
        <button class="hamburger" id="hamburger" aria-label="menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </header>

  <nav class="mobile-nav" id="mobileNav">
    <a href="#menu">{ui.nav_menu}</a>
    <a href="#access">{ui.nav_access}</a>
    <a href="#reservation">{ui.nav_reservation}</a>
    <a href={homeHref}>{ui.back_to_list}</a>
  </nav>

  <main class="spa-main">
    <slot />
  </main>

  <footer>
    <div class="footer-inner">
      <p>&copy; 2026 {siteName}. {ui.footer_rights}</p>
      <p style="margin-top:0.6rem;"><a href={homeHref}>{ui.back_to_list}</a></p>
    </div>
  </footer>

  <script>
    // JS 有効を明示（no-js フォールバックの解除）
    document.body.classList.remove('no-js');

    // ハンバーガーメニュー
    const btn = document.getElementById('hamburger');
    const nav = document.getElementById('mobileNav');
    if (btn && nav) {
      btn.addEventListener('click', () => {
        const isOpen = nav.classList.toggle('open');
        btn.classList.toggle('open', isOpen);
        btn.setAttribute('aria-expanded', String(isOpen));
      });
      nav.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          nav.classList.remove('open');
          btn.classList.remove('open');
          btn.setAttribute('aria-expanded', 'false');
        });
      });
    }

    // スクロール連動フェードイン（軽量・外部依存なし）
    const animated = Array.from(document.querySelectorAll('[data-animate]'));
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce || !('IntersectionObserver' in window)) {
      animated.forEach(el => el.classList.add('in'));
    } else {
      const io = new IntersectionObserver((entries, obs) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in');
            obs.unobserve(entry.target);
          }
        });
      }, { rootMargin: '0px 0px -8% 0px', threshold: 0.08 });
      animated.forEach(el => io.observe(el));
      // ヒーローは即時表示（初回ロード演出）
      requestAnimationFrame(() => {
        document.querySelectorAll('#hero [data-animate]').forEach(el => el.classList.add('in'));
      });
    }
  </script>
</body>
</html>
