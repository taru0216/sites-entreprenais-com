---
// /foodre/{retty_id}/menu/ — 店舗メニュー一覧ページ（#255 / #245）
//
// store.json の menu[] 全件をグリッド表示する。
// 各料理カードは /foodre/{retty_id}/menu/{dish_slug}/ へのリンクを持つ。

import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { UI } from '../../../../lib/i18n';
import type { Store } from '../../../../lib/store';

export function getStaticPaths() {
  const mods = import.meta.glob<{ default: Store }>('../../../../data/stores/*.json', { eager: true });
  return Object.values(mods).map((m) => ({
    params: { id: m.default.retty_id },
    props: { store: m.default },
  }));
}

const { store } = Astro.props as { store: Store };
const menu = store.menu ?? store.featured_menu ?? [];
const storeUrl = `/foodre/${store.retty_id}/`;
---

<BaseLayout
  title={`${store.name} — メニュー一覧`}
  siteName={store.name}
  description={`${store.name}のメニュー一覧。${menu.length}品掲載。`}
>
  <!-- パンくず -->
  <nav style="padding:1.25rem 1.5rem; background:#0a0a0a; border-bottom:1px solid #1a1a1a;">
    <a href={storeUrl} style="color:var(--orange); font-size:0.9rem; text-decoration:none;">← {store.name} トップ</a>
  </nav>

  <!-- ヘッダー -->
  <section style="padding:4rem 1.5rem 2rem; background:#000; text-align:center;">
    <p style="font-size:0.85rem; color:#666; letter-spacing:0.2em; margin-bottom:0.5rem;">MENU</p>
    <h1 style="font-size:clamp(1.8rem,6vw,3rem); color:var(--orange); margin-bottom:0.5rem;">{store.name}</h1>
    <p style="color:#bbb; font-size:1rem;">メニュー一覧 <span style="color:#666;">({menu.length}品)</span></p>
  </section>

  <!-- メニューグリッド -->
  <section style="padding:3rem 0 5rem; background:#000;">
    <div class="section-inner">
      {menu.length > 0 ? (
        <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:1.5rem;">
          {menu.map((item) => (
            <a
              href={item.dish_slug ? `/foodre/${store.retty_id}/menu/${item.dish_slug}/` : undefined}
              style={`display:block; background:#111; border:1px solid #222; border-radius:8px; overflow:hidden; text-decoration:none; ${item.dish_slug ? 'cursor:pointer;' : ''}`}
            >
              {item.photo_url && (
                <img
                  src={item.photo_url}
                  alt={item.name}
                  loading="lazy"
                  style="width:100%; height:180px; object-fit:cover; display:block;"
                />
              )}
              <div style="padding:1.25rem;">
                <h3 style="color:var(--orange); margin:0 0 0.5rem; font-size:1rem; line-height:1.4;">{item.name}</h3>
                {(item.price != null || item.price_raw) && (
                  <p style="color:#ddd; font-size:0.95rem; margin:0 0 0.5rem;">
                    {item.price_raw
                      ? item.price_raw
                      : (typeof item.price === 'number'
                          ? `${item.price.toLocaleString()}円`
                          : item.price)}
                  </p>
                )}
                {item.description && (
                  <p style="color:#888; font-size:0.85rem; line-height:1.6; margin:0;">{item.description}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p style="text-align:center; color:#666; padding:3rem 0;">{UI.no_menu}</p>
      )}
    </div>
  </section>

  <!-- フッターリンク -->
  <section style="padding:2rem 1.5rem; background:#0a0a0a; text-align:center;">
    <a href={storeUrl} style="display:inline-block; border:1px solid var(--orange); color:var(--orange); padding:0.65rem 2rem; border-radius:4px; font-size:0.9rem; text-decoration:none;">
      {store.name} のトップページへ
    </a>
  </section>
</BaseLayout>
